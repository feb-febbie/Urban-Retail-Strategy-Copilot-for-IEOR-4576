# Copy this file to .env and fill in at least ONE of the LLM keys below.
# The app auto-detects the best available provider in priority order.

# ── Option 1: Anthropic (paid) ────────────────────────────────────────────────
# console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Option 2: Groq (FREE tier — fast, no credit card needed) ─────────────────
# console.groq.com → create account → API Keys
GROQ_API_KEY=your_groq_api_key_here

# ── Option 3: Google Gemini (FREE tier) ───────────────────────────────────────
# aistudio.google.com → Get API key
GOOGLE_API_KEY=your_google_api_key_here

# ── Option 4: Ollama (fully local, no key needed) ─────────────────────────────
# Install: https://ollama.com  then run: ollama pull llama3.2
# No env var required — the app auto-detects a running Ollama instance.

# ── Optional: NYC Open Data token (reduces API rate limiting) ─────────────────
# data.cityofnewyork.us → sign in → Profile → App Tokens → Create
NYC_OPEN_DATA_APP_TOKEN=your_nyc_open_data_token_here
